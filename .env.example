# Same Supabase project as chrispyOS — copy values from your existing .env.local
# Vercel Supabase integration sets SUPABASE_URL + SUPABASE_SECRET_KEY instead.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: only needed for npm run setup:memento on a brand-new project
# SUPABASE_DB_URL=

# Optional: unavatar.io token for social profile photos
# NEXT_PUBLIC_UNAVATAR_TOKEN=
